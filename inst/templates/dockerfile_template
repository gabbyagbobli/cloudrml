# Dockerfile generated by cloudrml

FROM rocker/r-ver:4.3.0

# Install system dependencies
RUN apt-get update && apt-get install -y \
    libcurl4-openssl-dev \
    libssl-dev \
    libxml2-dev \
    && rm -rf /var/lib/apt/lists/*

# Install core R packages
RUN R -e "install.packages(c('plumber', 'jsonlite'))"

# Install model-specific packages
{{#extra_packages_exist}}
RUN R -e "install.packages(c({{{extra_packages}}}))"
{{/extra_packages_exist}}

# Copy application files
WORKDIR /app
COPY . .

# Set environment variables
ENV PORT=8080

# Command to run the API
ENTRYPOINT ["R", "-e", "pr <- plumber::plumb('plumber.R'); pr$run(host='0.0.0.0', port=as.numeric(Sys.getenv('PORT', '8080')))"]
